# Copy this file to .env and fill in values for local development.
# Never commit .env — it is git-ignored.

# Application
APP_NAME=jobregator
IMAGE_TAG=latest
PORT=8080

# Container registry (used by `make package`)
REGISTRY=ghcr.io/rdlucas2

# Adzuna API (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Remotive API (https://remotive.com/api-documentation — no key needed)
REMOTIVE_CATEGORIES=devops

# Scraper settings
LOOKBACK_HOURS=48

# Anthropic API (for MCP enrichment server)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
ENABLE_ENRICHMENT=true

# Discord notifications
DISCORD_WEBHOOK_URL=
FIT_SCORE_THRESHOLD=0.7

# SonarQube (used by `make sonar-scan`)
# Generate a token at http://localhost:9000 after running `make sonar-start`
SONAR_TOKEN=
