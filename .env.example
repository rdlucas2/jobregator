# Copy this file to .env and fill in values for local development.
# Never commit .env — it is git-ignored.

# Application
APP_NAME=jobregator
IMAGE_TAG=latest
PORT=8080

# Container registry (used by `make package`)
REGISTRY=ghcr.io/rdlucas2

# SonarQube (used by `make sonar-scan`)
# Generate a token at http://localhost:9000 after running `make sonar-start`
SONAR_TOKEN=
