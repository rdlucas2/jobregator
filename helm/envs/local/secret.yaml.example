apiVersion: v1
kind: Secret
metadata:
  name: jobregator-secrets
type: Opaque
stringData:
  ADZUNA_APP_ID: "your-adzuna-app-id"
  ADZUNA_APP_KEY: "your-adzuna-app-key"
  ANTHROPIC_API_KEY: "your-anthropic-api-key"
  DISCORD_WEBHOOK_URL: "your-discord-webhook-url"
  POSTGRES_DSN: "postgresql://jobregator:jobregator@postgres-postgresql:5432/jobregator"
